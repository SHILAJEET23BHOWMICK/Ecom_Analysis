-- ── Q9: On-Time vs Late Delivery Rate ───────────────────────
-- Business Question: How reliable is our delivery promise?
-- Metric          : On-Time Delivery Rate, Operational KPI

SELECT
    CASE
        WHEN order_delivered_customer_date <= order_estimated_delivery_date THEN 'On Time'
        WHEN order_delivered_customer_date >  order_estimated_delivery_date THEN 'Late'
        ELSE 'Not Delivered'
    END AS delivery_status,

    COUNT(*) AS total_orders,
    ROUND(COUNT(*) / SUM(COUNT(*)) OVER () * 100, 2) AS percentage,
    ROUND(AVG(delivery_days), 1) AS avg_delivery_days,
    ROUND(AVG(review_score), 2) AS avg_review_score,
    ROUND(AVG(total_payment), 2) AS avg_order_value

FROM ecommerce_master99
WHERE order_status = 'delivered'  -- Fixed: was delivery_status
GROUP BY 
    CASE
        WHEN order_delivered_customer_date <= order_estimated_delivery_date THEN 'On Time'
        WHEN order_delivered_customer_date >  order_estimated_delivery_date THEN 'Late'
        ELSE 'Not Delivered'
    END
ORDER BY total_orders DESC;

-- ── Q10: Late Delivery Impact on Review Score ────────────────
-- Business Question: Does late delivery cause bad reviews?
-- Metric          : Correlation — Delivery Performance vs Satisfaction

WITH delivery_analysis AS (
    SELECT
        order_id,
        review_score,
        delivery_days,
        DATEDIFF(order_delivered_customer_date,
                 order_estimated_delivery_date)         AS days_late,
        total_payment
    FROM ecommerce_master
    WHERE delivery_status  = 'delivered'
      AND review_score     IS NOT NULL
)
SELECT
    CASE
        WHEN days_late <= 0              THEN '1. On Time or Early'
        WHEN days_late BETWEEN 1 AND 7   THEN '2. Late (1-7 days)'
        WHEN days_late BETWEEN 8 AND 14  THEN '3. Late (8-14 days)'
        WHEN days_late BETWEEN 15 AND 30 THEN '4. Late (15-30 days)'
        ELSE                                  '5. Very Late (30+ days)'
    END                                                 AS lateness_bucket,

    COUNT(*)                                            AS total_orders,
    ROUND(AVG(review_score), 2)                         AS avg_review_score,
    ROUND(AVG(total_payment), 2)                        AS avg_order_value,

    -- % of dissatisfied customers (score 1-2)
    ROUND(SUM(CASE WHEN review_score <= 2
              THEN 1 ELSE 0 END)
              / COUNT(*) * 100, 2)                      AS dissatisfied_pct,

    -- % of happy customers (score 4-5)
    ROUND(SUM(CASE WHEN review_score >= 4
              THEN 1 ELSE 0 END)
              / COUNT(*) * 100, 2)                      AS satisfied_pct

FROM delivery_analysis
GROUP BY lateness_bucket
ORDER BY lateness_bucket;
