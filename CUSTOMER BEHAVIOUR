 ── Q6: Repeat vs One-Time Buyer Rate ───────────────────────
-- Business Question: How many customers come back?
-- Metric          : Retention Rate, Repeat Purchase Rate

WITH customer_orders AS (
    SELECT
        customer_unique_id,
        COUNT(DISTINCT order_id)        AS total_orders,
        ROUND(SUM(total_payment), 2)    AS lifetime_value
    FROM ecommerce_master99
    WHERE order_status = 'delivered'
    GROUP BY customer_unique_id
)
SELECT
    COUNT(*)                            AS total_customers,
    SUM(CASE WHEN total_orders = 1
             THEN 1 ELSE 0 END)         AS one_time_buyers,
    SUM(CASE WHEN total_orders > 1
             THEN 1 ELSE 0 END)         AS repeat_buyers,
    ROUND(SUM(CASE WHEN total_orders > 1
              THEN 1 ELSE 0 END)
              / COUNT(*) * 100, 2)      AS repeat_rate_pct,
    ROUND(AVG(lifetime_value), 2)       AS avg_customer_ltv,
    ROUND(AVG(CASE WHEN total_orders > 1
              THEN lifetime_value END), 2) AS repeat_buyer_ltv
FROM customer_orders;



-- ── Q7: Cohort Retention by First Purchase Month ────────────
-- Business Question: Which customer cohort retains best?
-- Metric          : Cohort Retention Rate

WITH customer_cohorts AS (
    SELECT
        customer_id,
        DATE_FORMAT(MIN(order_purchase_timestamp),
                    '%Y-%m')                            AS cohort_month,
        COUNT(DISTINCT order_id)                        AS total_orders
    FROM ecommerce_master
    WHERE order_status = 'delivered'
    GROUP BY customer_id
)
SELECT
    cohort_month,
    COUNT(customer_id)                                  AS cohort_size,

    SUM(CASE WHEN total_orders > 1
             THEN 1 ELSE 0 END)                         AS retained_customers,

    ROUND(SUM(CASE WHEN total_orders > 1
              THEN 1 ELSE 0 END)
              / COUNT(*) * 100, 2)                      AS retention_rate_pct,

    ROUND(AVG(total_orders), 2)                         AS avg_orders_per_customer

FROM customer_cohorts
GROUP BY cohort_month
ORDER BY cohort_month;

-- ── Q8: AOV by Payment Method ────────────────────────────────
-- Business Question: Which payment type drives highest order value?
-- Metric          : Average Order Value (AOV)

SELECT
    payment_types                                       AS payment_method,
    COUNT(DISTINCT order_id)                            AS total_orders,
    ROUND(SUM(total_payment), 2)                        AS total_revenue,
    ROUND(AVG(total_payment), 2)                        AS avg_order_value,
    ROUND(MAX(total_payment), 2)                        AS max_order_value,
    ROUND(MIN(total_payment), 2)                        AS min_order_value,
    ROUND(AVG(installments), 1)                         AS avg_installments
FROM ecommerce_master99
WHERE order_status = 'delivered'
  AND payment_types IS NOT NULL
GROUP BY payment_types
ORDER BY avg_order_value DESC;

